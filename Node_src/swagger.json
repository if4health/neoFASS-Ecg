        "resourceType"
      ],
      "properties": {
        "resourceType": {
          "type": "string"
        }
      }
    },
    "token": {
      "required": [
        "grant_type"
      ],
      "properties": {
        "grant_type": {
          "type": "string",
          "enum": ["authorization_code", "client_credentials"]
        },
        "client_id": {
          "type": "string",
          "example": "neofass"
        },
        "redirect_uri": {
          "type": "string",
          "example": "/biosignalinfhir/api-docs"
        },
        "scope": {
          "type": "string",
          "example": "user/*.crudsh"
        },
        "code": {
          "type": "string",
          "example": "123"
        }
      }
    }
